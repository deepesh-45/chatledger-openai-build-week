# Create a local .env file from this template and paste your own key.
OPENAI_API_KEY=your_openai_api_key_here
# Optional fallback for chat extraction and receipt reading when OpenAI is unavailable.
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
